{
  "name": "bmp-reader",
  "version": "0.1.0",
  "description": "Decode Bundeseinheitlicher Medikationsplan (BMP) scanner payloads.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:demo": "rolldown src/index.ts --file docs/assets/bmp-reader.browser.js --format esm --platform browser --minify --sourcemap",
    "demo:dev": "vite --host 127.0.0.1 docs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/pngjs": "^6.0.5",
    "bwip-js": "^4.11.1",
    "pngjs": "^7.0.0",
    "rolldown": "^1.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zxing-wasm": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
